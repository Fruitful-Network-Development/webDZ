      "header": "full: graphic + logo + nav",
      "main": [
        {
          "section": "section.hero",
          "containers": [".hero-parallax (bg via CSS)", ".hero-body"],
          "images_html": ["/assets/graphics/graphic-header.avif"],
          "content": ["Website update in progress", "Coming Soon"]
        }
      ],
      "scripts": []

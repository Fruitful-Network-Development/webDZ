{
  "_description": "Snapshot of the static frontend: HTML files, image asset paths (relative to site root), section/container patterns, and concise content labels. Paths use leading slash like layout.json (/assets/...).",
  "global_assets": {
    "stylesheets": ["css/style.css"],
    "favicon": "favicon.svg",
    "header": {
      "graphic_avif": "/assets/graphics/graphic-header.avif",
      "note": "Shown only on index.html and home.html inside .header-graphic; other pages omit the graphic."
    },
    "footer": {
      "graphic_avif": "/assets/graphics/graphic-footer.avif",
      "instagram_svg": "/assets/icon/logos/logo-instagram.svg"
    },
    "hero_background": {
      "avif": "/assets/images/farm_landscape.avif",
      "applied_in_css": "css/sections/hero.css (.hero-parallax background-image)"
    },
    "nav_icon_masks": {
      "pattern": "CSS mask-image on .nav-with-icons a::before in css/style.css",
      "paths": [
        "/assets/icon/ui/icon-home.svg",
        "/assets/icon/ui/icon-info.svg",
        "/assets/icon/ui/icon-data.svg",
        "/assets/icon/ui/icon-relationship.svg",
        "/assets/icon/ui/icon-inbox.svg",
        "/assets/icon/ui/icon-tools.svg"
      ]
    },
    "other_ui_icons_in_css": [
      "/assets/icon/icon-location.svg",
      "/assets/icon/ui/icon-time.svg",
      "/assets/icon/icon-mail.svg"
    ]
  },
  "layout_vocabulary": {
    "site_shell": "header.site-header > .header-inner | main.main | footer.site-footer > .footer-inner + .footer-bottom",
    "max_width": "1100px (--width in css/style.css); .header-inner, .container, .footer-inner align to this",
    "inner_page_section": "section.page-section > .container (most inner pages)",
    "hero_page": "section.hero > .hero-parallax + .hero-body (index.html, home.html; body.home-page)",
    "content_patterns": [
      ".section-block — text + media column layouts",
      ".section-split — .panel-text + .panel-image (e.g. slideshow)",
      ".slideshow-artifact — .slideshow-viewport / .slideshow-track / .slide",
      ".artifact — .artifact-media img + .artifact-caption",
      ".key-points — h4 + ul",
      ".subsection — h3 + paragraphs",
      ".landing-redesign — home panels: .landing-panel.visit-panel, .highlights-panel > .highlight-grid > .highlight-card",
      ".media-item — info.html podcast rows: img + text column",
      ".newsletter-issue — newsletter section body"
    ]
  },
  "navigation": {
    "links": [
      { "label": "About", "href": "about.html" },
      { "label": "Making the Crops", "href": "crops.html" },
      { "label": "Animal Husbandry", "href": "animals.html" },
      { "label": "For Your Homestead", "href": "homestead.html" },
      { "label": "Newsletters", "href": "newsletter.html" },
      { "label": "More Info", "href": "info.html" },
      { "label": "Projects", "href": "projects.html" }
    ],
    "logo": { "href": "home.html", "markup": ".logo > .logo-text (TRAPP / FAMILY / FARM)" }
  },
  "pages": {
    "index.html": {
      "title": "Trapp Family Farm | Coming Soon",

# Keycloak
# sudo nano /srv/compose/platform/.env
KEYCLOAK_ADMIN=admin
# sets `admin` as the boot temporary admin
KEYCLOAK_ADMIN_PASSWORD=<STRONG_ADMIN_PASSWORD>
KEYCLOAK_DB_PASSWORD=<STRONG_KEYCLOAK_DB_PASSWORD>

# BFF 
KC_REALM=fruitful
OIDC_CLIENT_ID=flask-bff
OIDC_CLIENT_SECRET=<STRONG_RANDOM_SECRET>

SESSION_SECRET=<STRONG_RANDOM_SESSION_SECRET>
COOKIE_SECURE=true
PUBLIC_BASE_URL=https://api.fruitfulnetworkdevelopment.com
PLATFORM_DB_URL=postgresql://platform:platform@platform_db:5432/platform

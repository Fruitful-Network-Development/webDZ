# Keycloak/Postgres secrets
KC_DB_PASSWORD= # strong database password
KEYCLOAK_ADMIN= # admin username (e.g., admin)
KEYCLOAK_ADMIN_PASSWORD= # strong admin password

# Keycloak realm used by the BFF
KC_REALM= # realm name (e.g., platform)

# OIDC client credentials for the BFF
OIDC_CLIENT_ID= # OIDC client ID
OIDC_CLIENT_SECRET= # strong client secret

# Session security
SESSION_SECRET= # long random secret used to sign sessions
